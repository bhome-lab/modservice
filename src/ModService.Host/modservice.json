{
  "ModService": {
    "polling": {
      "intervalSeconds": 300,
      "jitterSeconds": 30
    },
    "processMonitoring": {
      "enabled": true,
      "scanIntervalSeconds": 2
    },
    "executor": {
      "source": "core",
      "asset": "injector.dll",
      "options": [
        {
          "name": "mode",
          "value": "load-library"
        }
      ]
    },
    "sources": [
      {
        "id": "core",
        "repo": "owner/core-mods",
        "tag": "stable"
      }
    ],
    "rules": [
      {
        "name": "example",
        "process": "game*.exe",
        "bindings": [
          {
            "source": "core",
            "include": [
              "*.dll"
            ]
          }
        ],
        "executorOptions": [
          {
            "name": "profile",
            "value": "main"
          }
        ],
        "passEnvironment": [
          "MODSERVICE_PROFILE"
        ]
      }
    ]
  }
}
