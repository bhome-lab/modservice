{
  "ModService": {
    "polling": {
      "intervalSeconds": 5,
      "jitterSeconds": 2
    },
    "processMonitoring": {
      "enabled": true,
      "scanIntervalSeconds": 2
    },
    "executor": {
      "source": "repo",
      "asset": "NativeExecutor.dll",
      "options": [
        {
          "name": "mode",
          "value": "safe-smoke"
        }
      ]
    },
    "sources": [
      {
        "id": "repo",
        "repo": "bhome-lab/modservice",
        "tag": "latest",
        "include": [
          "NativeExecutor.dll",
          "SampleModule.dll"
        ]
      }
    ],
    "rules": [
      {
        "name": "testtarget-self-load",
        "process": "ModService.TestTarget.exe",
        "bindings": [
          {
            "source": "repo",
            "include": [
              "SampleModule.dll"
            ]
          }
        ],
        "applyEnvironment": {
          "MODSERVICE_SAMPLE_MARKER": "service-sample-marker",
          "MODSERVICE_SAMPLE_OUTPUT": "C:\\ProgramData\\ModService\\sample-output.txt"
        }
      }
    ]
  }
}
