{
  "ModService": {
    "polling": {
      "intervalSeconds": 300,
      "jitterSeconds": 30
    },
    "executor": {
      "source": "core",
      "asset": "injector.dll"
    },
    "sources": [
      {
        "id": "core",
        "repo": "owner/core-mods",
        "tag": "stable"
      }
    ],
    "rules": [
      {
        "name": "example",
        "process": "game*.exe",
        "bindings": [
          {
            "source": "core",
            "include": [
              "*.dll"
            ]
          }
        ],
        "passEnvironment": [
          "MODSERVICE_PROFILE"
        ]
      }
    ]
  }
}
